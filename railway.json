{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "nixpacks"
  },
  "deploy": {
    "numReplicas": 1,
    "startCommand": "npm run build && npm run preview",
    "restartPolicyMaxRetries": 5,
    "restartPolicyWindowMs": 60000,
    "healthchecks": {
      "cpuThreshold": 80,
      "memoryThreshold": 80
    }
  }
}
